<?xml version="1.0"?>
<odoo>
    <record id="crm_api_view_form" model="ir.ui.view">
        <field name="name">indiamartapi.api.view</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="crm.res_config_settings_view_form"/>
        <field name="arch" type="xml">   
        <data>
			<xpath expr="//div[@name='generate_lead_setting_container']" position="after">
			<h2>IndiaMART API</h2>
			<div class="row mt16 o_settings_container">
            <div class="col-12 col-lg-6 o_setting_box">
            <div class="o_setting_right_pane">
            <span class="o_form_label">IndiaMART API Key :-  <field name="IndiaMART_API_KEY" password="True"/></span>
            <div class="text-muted">Input the API Key taken from IndiaMART.</div>
			</div>
			</div>
			</div>
			</xpath>
            </data>
		</field>
    </record>
</odoo>